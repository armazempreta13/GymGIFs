export default function LandingPage() {
  const jsonLd = {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "GymGIFs",
    "description": siteConfig.seo.description,
    "image": siteConfig.seo.openGraph.images[0].url,
    "offers": {
      "@type": "Offer",
      "priceCurrency": "BRL",
      "price": siteConfig.pricing.mainCard.price + "." + siteConfig.pricing.mainCard.cents.replace(',', ''),
      "availability": "https://schema.org/InStock",
      "url": siteConfig.seo.url
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "2400"
    }
  };

  const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": siteConfig.faq.items.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a
      }
    }))
  };

  const [timeLeft, setTimeLeft] = useState({ hours: 12, minutes: 45, seconds: 0 });

  useEffect(() => {
    const timer = setInterval(() => {
      setTimeLeft(prev => {
        let { hours, minutes, seconds } = prev;
        if (seconds > 0) seconds--;
        else if (minutes > 0) { minutes--; seconds = 59; }
        else if (hours > 0) { hours--; minutes = 59; seconds = 59; }
        return { hours, minutes, seconds };
      });
    }, 1000);
    return () => clearInterval(timer);
  }, []);

  return (
    <div className="min-h-screen bg-[#0F0F0F] text-white selection:bg-[#00E676] selection:text-[#0F0F0F] font-['Inter',system-ui] pb-20 md:pb-0 relative">
      <script
        type="application/ld+json"
        dangerouslySetInnerHTML={{ __html: JSON.stringify(jsonLd) }}
      />
      <script
        type="application/ld+json"
        dangerouslySetInnerHTML={{ __html: JSON.stringify(faqSchema) }}
      />
      <header>
        <Hero />
      </header>
      <main>
        <TargetAudience />
        <ProductPreview />
        <Advantages />
        <Testimonials />
        <CountdownBanner timeLeft={timeLeft} />
        <Pricing />
        <FAQ />
        <FinalCTA />
      </main>
      <Footer />
      <StickyMobileCTA />
    </div>
  );
}

